<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monarch Styling Foundation | Empowering Trade Professionals</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <style>
        .hero-gradient { background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%); }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 font-sans">

    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <span class="text-xl font-bold tracking-tight text-blue-900">MONARCH STYLING FOUNDATION</span>
            <div class="space-x-6 text-sm font-medium">
                <a href="#about" class="hover:text-blue-600 transition">About</a>
                <a href="#workshops" class="hover:text-blue-600 transition">Workshops</a>
                <a href="#sponsors" class="hover:text-blue-600 transition">Sponsors</a>
                <a href="mailto:partnership@monarchstylingfoundation.org" class="bg-blue-900 text-white px-4 py-2 rounded-md hover:bg-blue-800 transition">Contact Us</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero-gradient text-white py-24 px-4 text-center">
        <div class="max-w-3xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Empowering the Next Generation of Styling Professionals</h1>
            <p class="text-lg opacity-90 mb-8">We provide resources, workshops, and community support for trade professionals in the beauty and barbering industry.</p>
            <a href="#sponsors" class="bg-white text-blue-900 px-8 py-3 rounded-full font-bold shadow-lg hover:bg-gray-100 transition">Become a Sponsor</a>
        </div>
    </header>

    <!-- Mission Section -->
    <section id="about" class="py-20 max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-12 text-center">
        <div>
            <div class="text-3xl mb-4">✂️</div>
            <h3 class="text-xl font-bold mb-2">Vocational Training</h3>
            <p class="text-gray-600">Expert-led workshops designed to sharpen skills and build sustainable careers.</p>
        </div>
        <div>
            <div class="text-3xl mb-4">🤝</div>
            <h3 class="text-xl font-bold mb-2">Community Pop-ups</h3>
            <p class="text-gray-600">Bringing professional services and resources directly to the neighborhoods that need them.</p>
        </div>
        <div>
            <div class="text-3xl mb-4">📈</div>
            <h3 class="text-xl font-bold mb-2">Entrepreneurship</h3>
            <p class="text-gray-600">Guidance for professionals looking to launch their own businesses and schools.</p>
        </div>
    </section>

    <!-- Sponsorship Section -->
    <section id="sponsors" class="bg-blue-50 py-20">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-4">Partner with the Monarch Styling Foundation</h2>
            <p class="text-gray-700 mb-10">We are looking for visionary sponsors to help fund our Summer 2026 initiatives. Your support directly impacts the Dallas trade community.</p>
            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h4 class="font-bold text-blue-900">Corporate Partners</h4>
                    <p class="text-sm text-gray-500 mt-2">Brand visibility at our large-scale community events.</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h4 class="font-bold text-blue-900">Resource Sponsors</h4>
                    <p class="text-sm text-gray-500 mt-2">Funding for tools and workshop supplies for students.</p>
                </div>
            </div>
            <p class="mt-10 font-semibold">Interested? Email us at <br> <span class="text-blue-700">partnership@monarchstylingfoundation.org</span></p>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 text-center text-gray-500 text-sm">
        <p>&copy; 2026 Monarch Styling Foundation. All rights reserved.</p>
    </footer>

</body>
</html>
